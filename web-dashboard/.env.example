# Copy to .env.local for local dev. On Netlify, set these in Site settings → Environment variables.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Legacy JWT service_role or newer sb_secret_* (Supabase → Settings → API). Never expose to the client.
# Required for /api/health counts and /api/inbox/messages (loads social rows even if RLS blocks the anon key).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_server_only
# Optional alias used by some templates for the secret key:
# SUPABASE_SECRET_KEY=
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=use_a_long_random_password
DASHBOARD_AUTH_SECRET=use_a_long_random_secret_32_plus_chars
DASHBOARD_ALLOWED_IPS=203.0.113.10,198.51.100.22
