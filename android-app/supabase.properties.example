# Copy to supabase.properties (do not commit supabase.properties).
# Rebuild the APK after editing.

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Prefer anon/publishable key on the phone; service role is powerful — only for private builds.
# SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=your-anon-or-sb_publishable_key
# If SERVICE_ROLE is set, it overrides ANON for REST calls (same as dashboard server).
